{
    "server": {
        "host": "0.0.0.0",
        "port": 8080,
        "threads": 4
    },
    "memgraph": {
        "host": "memgraph",
        "port": 7687,
        "username": "",
        "password": "",
        "pool_size": 3,
        "memory_limit_mb": 1800
    },
    "crawler": {
        "max_threads": 4,
        "rate_limit_ms": 3000,
        "bloom_filter_size_mb": 10,
        "bloom_filter_path": "data/urls.bloom"
