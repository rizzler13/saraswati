    "sources": {
        "arxiv": {
            "enabled": true,
            "feeds": ["cs.AI", "cs.LG", "cs.CL"],
            "poll_interval_seconds": 300
        },
        "biorxiv": {
            "enabled": true,
            "keywords": ["CRISPR", "mRNA", "Longevity"],
            "poll_interval_seconds": 300
        },
        "huggingface": {
            "enabled": true,
            "poll_interval_seconds": 300
        }
    },
    "discourse": {
        "reddit": {
            "enabled": true,
            "subreddits": ["MachineLearning", "LocalLLaMA", "science"],
            "poll_interval_seconds": 300
        },
        "twitter": {
            "enabled": false,
            "nitter_instances": [],
            "influencers": [],
            "poll_interval_seconds": 600
        },
        "hackernews": {
            "enabled": true,
            "poll_interval_seconds": 300
        }
    },
    "enrichment": {
        "semantic_scholar": {
            "enabled": true,
            "api_key": "",
