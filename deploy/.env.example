# Saraswati Production Environment Variables
# Copy this to .env and fill in your values

# Domain for the API backend (Caddy auto-provisions HTTPS)
# Use a DuckDNS subdomain for free: saraswati.duckdns.org
# Or your own domain: api.yourdomain.com
DOMAIN=saraswati.duckdns.org

# Frontend URL (for CORS headers)
# This is where your Vercel-deployed frontend lives
FRONTEND_URL=https://saraswati.vercel.app

# Docker image for the backend (used for CI/CD pulls)
BACKEND_IMAGE=ghcr.io/rizzler13/saraswati-backend:latest

# Memgraph memory limit in MB
MG_MEMORY_LIMIT=1800

# Optional: Semantic Scholar API key for enrichment
SEMANTIC_SCHOLAR_API_KEY=

# Optional: Gemini API key for AI summaries
GEMINI_API_KEY=
