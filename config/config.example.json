        },
        "gemini": {
            "enabled": false,
            "api_key": "",
            "model": "gemini-1.5-flash",
            "rate_limit_ms": 500
        }
    },
    "logging": {
        "level": "info",
        "file": "logs/saraswati.log"
    }
