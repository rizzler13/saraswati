{
    "server": {
        "host": "0.0.0.0",
        "port": 8080,
        "threads": 4
    },
    "memgraph": {
        "host": "localhost",
        "port": 7687,
        "username": "",
        "password": "",
        "pool_size": 3,
        "memory_limit_mb": 1800
    },
    "crawler": {
        "max_threads": 8,
        "rate_limit_ms": 2000,
        "bloom_filter_size_mb": 10,
        "bloom_filter_path": "data/urls.bloom"
    },
    "sources": {
        "arxiv": {
            "enabled": true,
            "feeds": [
                "cs.AI",
                "cs.LG",
                "cs.CL"
            ],
            "poll_interval_seconds": 60
        },
        "biorxiv": {
            "enabled": true,
            "keywords": [
                "CRISPR",
                "mRNA",
                "Longevity"
            ],
            "poll_interval_seconds": 60
        },
        "huggingface": {
            "enabled": true,
            "poll_interval_seconds": 60
        }
    },
    "discourse": {
        "reddit": {
            "enabled": true,
            "subreddits": [
                "MachineLearning",
                "LocalLLaMA",
                "science"
            ],
            "poll_interval_seconds": 60
        },
        "twitter": {
            "enabled": true,
            "nitter_instances": [
                "https://nitter.net",
                "https://nitter.it",
                "https://nitter.privacydev.net"
            ],
            "influencers": [
                "karpathy",
                "yannlecun",
                "AndrewYNg"
            ],
            "poll_interval_seconds": 120
        },
        "hackernews": {
            "enabled": true,
            "poll_interval_seconds": 60
        }
    },
    "enrichment": {
        "semantic_scholar": {
            "enabled": true,
